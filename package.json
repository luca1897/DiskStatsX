{
  "name": "diskstatsx",
  "version": "1.1.0",
  "description": "Native macOS disk space analyzer powered by getattrlistbulk, D3 and Electron.",
  "private": true,
  "main": "electron-main.js",
  "scripts": {
    "build:scanner": "make",
    "start": "node server.js",
    "desktop": "npm run build:scanner && electron .",
    "package:mac": "npm run build:scanner && electron-builder --mac dmg zip",
    "dist": "npm run package:mac",
    "lint": "eslint electron-main.js preload.js server.js server public/js public/treemap-worker.js test",
    "test": "npm run build:scanner && node --test",
    "check": "npm run lint && npm test",
    "clean": "make clean && rm -rf dist"
  },
  "keywords": [
    "macos",
    "getattrlistbulk",
    "apfs",
    "disk",
    "sunburst",
    "treemap"
  ],
  "author": "luca1897",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luca1897/DiskStatsX.git"
  },
  "homepage": "https://github.com/luca1897/DiskStatsX#readme",
  "bugs": {
    "url": "https://github.com/luca1897/DiskStatsX/issues"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4"
  },
  "build": {
    "appId": "com.diskstatsx.app",
    "productName": "DiskStatsX",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "asar": true,
    "files": [
      "electron-main.js",
      "preload.js",
      "server.js",
      "server/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "scanner",
        "to": "scanner"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
